{
  "version": 2,
  "cleanUrls": true,
  "buildCommand": "echo 'Static build'",
  "outputDirectory": "web",
  "redirects": [
    {
      "source": "/",
      "destination": "/app/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/app/styles.css",
      "destination": "/styles.css"
    },
    {
      "source": "/app/app.js",
      "destination": "/app.js"
    },
    {
      "source": "/app/",
      "destination": "/index.html"
    },
    {
      "source": "/app",
      "destination": "/index.html"
    }
  ]
}
