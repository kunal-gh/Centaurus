# ── Core Services ────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=
OPENAI_API_KEY=

# Set to 1 to run fully offline (no OpenAI, no Supabase, deterministic mocks)
CENTAURUS_MOCK_MODE=

# ── Wave 1: Qdrant Vector DB ──────────────────────────────────────────────────
# Leave blank to use local SQLite-backed Qdrant (default, no Docker needed)
# Set to your Qdrant Cloud cluster URL + API key for cloud retrieval
QDRANT_URL=
QDRANT_API_KEY=

# ── Wave 2: Langfuse Observability ────────────────────────────────────────────
# Option A: Langfuse Cloud (free up to 50k traces/month) → https://cloud.langfuse.com
# Option B: Self-hosted → set LANGFUSE_HOST=http://localhost:3000
# Leave blank to disable tracing (app continues to work normally)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Wave 3: Neo4j Graph Database ──────────────────────────────────────────────
# URL to local docker container (bolt://localhost:7687) or Neo4j Aura DB
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
